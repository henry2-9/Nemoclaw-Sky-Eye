#!/usr/bin/env python3
"""Inspect incident flight-recorder timelines."""
import argparse
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import flight_recorder


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--trace-id", help="show one full incident timeline")
    ap.add_argument("--latest", type=int, default=5, help="list latest traces")
    ap.add_argument("--json", action="store_true", help="emit JSON instead of text")
    ap.add_argument("--path", help="flight_recorder.jsonl path")
    args = ap.parse_args()

    rows = flight_recorder.load(args.path)
    traces = flight_recorder.group_by_trace(rows)

    if args.trace_id:
        selected = traces.get(args.trace_id, [])
        if args.json:
            print(json.dumps(selected, ensure_ascii=False, indent=2))
        else:
            print(flight_recorder.render_text(args.trace_id, selected))
        return

    latest = flight_recorder.latest_traces(rows, args.latest)
    if args.json:
        print(json.dumps({tid: recs for tid, recs in latest}, ensure_ascii=False, indent=2))
        return

    if not latest:
        print("No flight-recorder traces yet.")
        return
    print("Latest incident traces:")
    for tid, recs in latest:
        stages = " → ".join(r.get("stage", "") for r in recs)
        last = recs[-1].get("payload", {}) if recs else {}
        summary = last.get("summary") or last.get("decision") or ""
        print(f"- {tid} | {len(recs)} stages | {summary}")
        print(f"  {stages}")


if __name__ == "__main__":
    main()
