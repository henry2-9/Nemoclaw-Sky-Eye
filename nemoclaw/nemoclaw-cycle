#!/usr/bin/env python3
"""一次自主巡檢週期(確定性編排)。由 hermes cron / supervisor 重複呼叫。
sweep → 挑選 → Nemotron 確認分級 → nemoclaw-act 政策閘(唯一對外出口)。"""
import os, sys, json, time, subprocess
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import register_channels, sweep, orchestrator, act, audit, flight_recorder, nemoclaw_triage
import curiosity as _curiosity
import thoughts as _thoughts
import briefing as _briefing
import correlation as _correlation
import hermes_followup as _followup

NEMOCLAW_DIR = os.path.dirname(os.path.abspath(__file__))
TOOLS = os.path.normpath(os.path.join(NEMOCLAW_DIR, "..", "tools"))
ANALYZE = os.path.join(TOOLS, "sentinel-analyze-video.py")
ACT = os.path.join(NEMOCLAW_DIR, "nemoclaw-act")

def analyze_fn(channel, question):
    """Nemotron 確認+分級(8 幀跨全片,符合 vLLM image:8 上限)。回 answer 字串。"""
    try:
        out = subprocess.run(
            [sys.executable, ANALYZE, "--channel", str(channel),
             "--fps", "0.15", "--max-frames", "8", "--max-tokens", "256", "--question", question],
            capture_output=True, text=True, env=dict(os.environ), timeout=180).stdout
        return json.loads(out[out.index("{"):]).get("answer", "")
    except Exception:
        return ""

def act_fn(incident):
    """唯一對外出口:呼叫 nemoclaw-act 政策閘。"""
    try:
        proc = subprocess.run(
            [ACT, "--incident", json.dumps(incident, ensure_ascii=False)],
            capture_output=True, text=True, env=dict(os.environ), timeout=120)
        out = proc.stdout.strip()
        if proc.returncode == 0 and out.startswith("{"):
            return json.loads(out)
        reason = (proc.stderr or out or f"nemoclaw-act exited {proc.returncode}").strip()[:400]
    except Exception as e:
        reason = str(e)[:400]
    failure = {
        "decision": "ERROR",
        "actions": ["log"],
        "channels": [],
        "reasons": [f"action gate failure: {reason}"],
        "policy_hits": ["action_gate_failed"],
        "notification_sent": False,
        "ts": time.time(),
        "channel": incident.get("channel"),
        "event_type": incident.get("event_type"),
        "trace_id": incident.get("trace_id"),
        "severity": incident.get("severity"),
        "summary": incident.get("summary", ""),
        "governed_by": incident.get("governed_by", "local"),
        "trigger_origin": incident.get("trigger_origin", "scheduled"),
        "approval_required": False,
    }
    audit.append(failure, jsonl_path=os.environ.get("NEMOCLAW_AUDIT_PATH"))
    flight_recorder.record_stage(failure.get("trace_id"), "policy_decision", failure)
    _thoughts.record(
        f"ch{incident.get('channel')} 動作閘失敗,已留稽核:{reason[:90]}",
        source="decision")
    return failure

def _recent_handled(window):
    """冷卻窗內已處理(ALLOW)的 (channel, event_type),供選取時排除以輪巡 16 路。"""
    path = os.environ.get("NEMOCLAW_AUDIT_PATH")
    handled, now = set(), time.time()
    if path and os.path.exists(path):
        for line in open(path, encoding="utf-8"):
            try:
                r = json.loads(line)
                if r.get("decision") == "ALLOW" and (now - r.get("ts", 0)) <= window:
                    handled.add((str(r.get("channel")), r.get("event_type")))
            except Exception:
                pass
    return handled

def main():
    chans = register_channels.load_channels(
        register_channels.channels_file(),
        merge_discovered=register_channels.discovery_enabled(),
    )
    max_n = int(os.environ.get("NEMOCLAW_MAX_PER_CYCLE", "4"))
    window = act.load_policy().get("gating", {}).get("dedup_window_seconds", 300)
    exclude = _recent_handled(window)
    # 文字 triage 走真 NemoClaw-Hermes(:8642,受 OpenShell policy 管治);可用才接,否則降級
    triage_fn = None
    if os.environ.get("NEMOCLAW_TRIAGE", "1") == "1":
        triage_fn = lambda et, desc, ev: nemoclaw_triage.triage(et, desc, ev)
    followup_fn = None
    if os.environ.get("NEMOCLAW_FOLLOWUP", "1") == "1":
        followup_fn = _followup.run
    audit_p = os.environ.get("NEMOCLAW_AUDIT_PATH")
    def sweep_with_curiosity(channels):
        cands = sweep.sweep_channels(channels)
        pick = _curiosity.stale_pick(channels, audit_p)
        if pick:
            ch, idle_min = pick
            _thoughts.record(
                f"ch{ch['id']}({ch.get('name','')}) 已 {idle_min} 分沒巡——我主動去看看",
                source="curiosity")
            cands.append(_curiosity.curiosity_candidate(ch))
        return cands
    result = orchestrator.run_cycle(chans, sweep_with_curiosity, analyze_fn, act_fn,
                                    max_n=max_n, exclude=exclude, triage_fn=triage_fn,
                                    followup_fn=followup_fn)
    try:
        _correlation.scan()
    except Exception:
        pass
    summary = {
        "candidates": result["candidates"],
        "investigated": result["investigated"],
        "incidents": result["incidents"],
        "decisions": [r.get("decision") for r in result["results"]],
    }
    print(json.dumps(summary, ensure_ascii=False))
    _maybe_refresh_briefing()


def _maybe_refresh_briefing(min_age_seconds=900):
    """agent 自主重生情勢簡報:離上次超過 N 秒才動,避免每輪都打 Nemotron。"""
    p = _briefing.latest_path()
    if os.path.exists(p) and (time.time() - os.path.getmtime(p)) < min_age_seconds:
        return
    try:
        text = _briefing.generate_briefing(hours=1, vlm_fn=_briefing._vlm_text)
        if text:
            _briefing.write_latest(text)
            _thoughts.record(f"自主彙整過去 1 小時情勢:{text[:90]}", source="briefing")
    except Exception:
        pass

if __name__ == "__main__":
    main()
