# Sentinel 環境變數。用法:source nemoclaw/nemoclaw.env
# 機器專屬路徑/DB 放在 gitignored 的 nemoclaw.env.local(不進 repo)
_HERE="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
[ -f "$_HERE/nemoclaw.env.local" ] && . "$_HERE/nemoclaw.env.local"

# 中性預設(未提供 local 時用;不外洩任何內部名稱)
export SENTINEL_VENV="${SENTINEL_VENV:-$HOME/.venvs/nemoclaw}"
export SENTINEL_WORKSPACE="${SENTINEL_WORKSPACE:-$HOME/sentinel-workspace}"
export SENTINEL_REPO="${SENTINEL_REPO:-$(cd "$_HERE/.." && pwd)}"
export SENTINEL_DB="${SENTINEL_DB:-sentinel_db}"

export PATH="$SENTINEL_VENV/bin:$PATH"

# 核心模型:本機 Nemotron-Omni(vLLM)
export VLM_API_URL=http://127.0.0.1:31010/v1/chat/completions
export VLM_MODEL=nemotron_3_nano_omni
export VLM_API_KEY=nemotron
export AI_VERBOSE=0
export FALCON_PERCEPTION_SERVER=http://127.0.0.1:18793

# 真 NVIDIA NemoClaw Hermes agent(OpenShell 沙箱,文字 triage 走這,受 policy 管治)
export NEMOCLAW_HERMES_URL=http://127.0.0.1:8642/v1/chat/completions
export NEMOCLAW_TRIAGE=1
# 讓 `nemohermes status` 的 vLLM 健康探針指向我們的 Nemotron 埠
export NEMOCLAW_VLLM_PORT=31010

# 工作區 / DB(真實值來自 nemoclaw.env.local)
export SENTINEL_WORKSPACE
export NEMOCLAW_DB="$SENTINEL_DB"

# 專案路徑(衍生自 SENTINEL_REPO)
export NEMOCLAW_DIR="$SENTINEL_REPO/nemoclaw"
# channel 來源:預設本地 16 路影片;改指 world_channels.yaml 即切換世界公開攝影機
export NEMOCLAW_CHANNELS_FILE="${NEMOCLAW_CHANNELS_FILE:-$NEMOCLAW_DIR/channels.yaml}"
export NEMOCLAW_AUDIT_PATH="$NEMOCLAW_DIR/audit.jsonl"
export NEMOCLAW_FLIGHT_RECORDER=1
export NEMOCLAW_FLIGHT_RECORDER_PATH="$NEMOCLAW_DIR/flight_recorder.jsonl"
export NEMOCLAW_MEDIA_ENABLED=1
export NEMOCLAW_MEDIA_DIR="$NEMOCLAW_DIR/media_events"
export NEMOCLAW_DASHBOARD_PORT=8099
export NEMOCLAW_DASHBOARD_URL=http://127.0.0.1:${NEMOCLAW_DASHBOARD_PORT}
export NEMOCLAW_MAX_PER_CYCLE=4

# Telegram:bot token 從外部 secrets 檔取得(不進 repo)
set -a; [ -n "${SENTINEL_HERMES_ENV:-}" ] && [ -f "$SENTINEL_HERMES_ENV" ] && . "$SENTINEL_HERMES_ENV"; set +a
export TELEGRAM_CHAT_ID=${TELEGRAM_CHAT_ID:-8755477259}
# 本機覆寫(來自 gitignored nemoclaw.env.local;優先於 hermes .env 的 token)
[ -n "${SENTINEL_TELEGRAM_BOT_TOKEN:-}" ] && export TELEGRAM_BOT_TOKEN="$SENTINEL_TELEGRAM_BOT_TOKEN"
[ -n "${SENTINEL_TELEGRAM_CHAT_ID:-}" ] && export TELEGRAM_CHAT_ID="$SENTINEL_TELEGRAM_CHAT_ID"
