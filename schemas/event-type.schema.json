{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiunion.com.tw/schemas/event-type.schema.json",
  "title": "FPG Event Type",
  "description": "Schema for a single event-type YAML file under config/event-types/.",
  "type": "object",
  "required": ["id", "key", "name", "classes", "vlm"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Numeric type ID persisted in MongoDB. 1-99 reserved for built-ins, 100-999 for customer-defined, 1000+ for third-party plugins."
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "maxLength": 64,
      "description": "Machine-readable slug (lowercase, snake_case)."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable display name (any language)."
    },
    "description": { "type": "string" },
    "version": { "type": "integer", "default": 1, "minimum": 1 },
    "enabled": { "type": "boolean", "default": true },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "key", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "vlm": {
      "type": "object",
      "required": ["prompt"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "description": "Override VLM_MODEL for this event type (optional)."
        },
        "max_frames": { "type": "integer", "minimum": 1, "maximum": 64, "default": 8 },
        "max_tokens": { "type": "integer", "minimum": 32, "maximum": 8192, "default": 800 },
        "prefill": { "type": "string" },
        "prompt": { "type": "string", "minLength": 10 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
      }
    },
    "output_guards": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enforce_json": { "type": "boolean", "default": true },
        "no_thinking_leak": { "type": "boolean", "default": true },
        "description_length": {
          "type": "array",
          "description": "[min_chars, max_chars] — descriptions outside the range trigger fallback.",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "notifications": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "severity": { "enum": ["low", "medium", "high", "critical"], "default": "medium" },
        "throttle_seconds": { "type": "integer", "minimum": 0, "default": 0 },
        "default_channels": {
          "type": "array",
          "items": { "enum": ["line", "telegram", "email", "webhook"] }
        }
      }
    }
  }
}
