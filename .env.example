# ============================================================================
# FPG Appliance Configuration
#
# Copy this file to `.env` and fill in values. Do NOT commit `.env` to git.
# Fields marked [REQUIRED] must be set before `docker compose up`.
# ============================================================================

# ----------------------------------------------------------------------------
# Product identity
# ----------------------------------------------------------------------------
APP_VERSION=0.1.0
TZ=Asia/Taipei

# ----------------------------------------------------------------------------
# MongoDB  [REQUIRED]
# ----------------------------------------------------------------------------
MONGO_USERNAME=fpg_admin
MONGO_PASSWORD=change_me_to_a_strong_password
MONGO_DB_NAME=fpg

# ----------------------------------------------------------------------------
# VLM (Vision Language Model)  [REQUIRED]
# Place GGUF file under VLM_MODELS_HOST_PATH before starting.
# ----------------------------------------------------------------------------
VLM_MODELS_HOST_PATH=./models
VLM_MODEL_FILENAME=qwen3.6-35b-a3b-Q4_K_M.gguf
VLM_MODEL=qwen3.6-35b-a3b
VLM_CONTEXT_LENGTH=65536

# ----------------------------------------------------------------------------
# LINE channel  [REQUIRED if using LINE]
# From LINE Developers Console → Messaging API channel.
# ----------------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ----------------------------------------------------------------------------
# Telegram (optional)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=

# ----------------------------------------------------------------------------
# Google Gemini (optional, for image-generation tasks)
# ----------------------------------------------------------------------------
GOOGLE_API_KEY=

# ----------------------------------------------------------------------------
# Cloudflare Tunnel  [REQUIRED for public webhook]
# Dashboard: Zero Trust → Access → Tunnels
# Configure the public hostname to route to http://openclaw:18789
# ----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=
PUBLIC_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Data paths  [REQUIRED]
# Host directory for videos and event artifacts (can point at a NAS mount).
# ----------------------------------------------------------------------------
FPG_DATA_HOST_PATH=./data

# ----------------------------------------------------------------------------
# License (reserved — enforcement lands in a later phase)
# ----------------------------------------------------------------------------
LICENSE_KEY=
