# ============================================================================
# FPG Appliance Configuration
#
# Copy this file to `.env` and fill in values. Do NOT commit `.env` to git.
# Fields marked [REQUIRED] must be set before `docker compose up`.
# ============================================================================

# ----------------------------------------------------------------------------
# Product identity
# ----------------------------------------------------------------------------
APP_VERSION=0.1.0
TZ=Asia/Taipei

# ----------------------------------------------------------------------------
# MongoDB  [REQUIRED]
# ----------------------------------------------------------------------------
MONGO_USERNAME=fpg_admin
MONGO_PASSWORD=change_me_to_a_strong_password
MONGO_DB_NAME=fpg

# ----------------------------------------------------------------------------
# VLM (Vision Language Model)  [REQUIRED]
# Place GGUF + mmproj files under VLM_MODELS_HOST_PATH before starting.
# Vision is mandatory — without VLM_MMPROJ_FILENAME llama-server will only do
# text and the event-detection pipeline cannot see frames.
# ----------------------------------------------------------------------------
VLM_MODELS_HOST_PATH=/home/aiunion/.lmstudio/models/unsloth/Qwen3.6-35B-A3B-GGUF
VLM_MODEL_FILENAME=Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
VLM_MMPROJ_FILENAME=mmproj-F16.gguf
VLM_MODEL=qwen3.6-35b-a3b
VLM_CONTEXT_LENGTH=65536

# ----------------------------------------------------------------------------
# LINE channel  [REQUIRED if using LINE]
# ----------------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ----------------------------------------------------------------------------
# Telegram (optional)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=

# ----------------------------------------------------------------------------
# Google Gemini (optional, used for image-generation prompts only)
# ----------------------------------------------------------------------------
GOOGLE_API_KEY=

# ----------------------------------------------------------------------------
# Cloudflare Tunnel  [REQUIRED for public webhook]
# Configure the public hostname to route to http://openclaw:18789
# ----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=
PUBLIC_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Pictshare (image hosting)
# Used by fpg-perception / fpg-video-ingest to surface annotated frames in
# LINE messages. Leave blank to disable image attachments (events still log).
# ----------------------------------------------------------------------------
PICTSHARE_URL=
PICTSHARE_UPLOAD_CODE=

# ----------------------------------------------------------------------------
# Data paths  [REQUIRED]
# Host directory for videos and event artifacts (can point at a NAS mount).
# ----------------------------------------------------------------------------
FPG_DATA_HOST_PATH=./data

# ----------------------------------------------------------------------------
# License (reserved — enforcement lands in a later phase)
# ----------------------------------------------------------------------------
LICENSE_KEY=
